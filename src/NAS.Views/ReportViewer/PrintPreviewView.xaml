<Grid x:Class="NAS.Views.ReportViewer.PrintPreviewView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:my="clr-namespace:NAS.Views.ReportViewer"
      xmlns:printing="clr-namespace:NAS.ViewModels.Printing;assembly=NAS.ViewModels"
      xmlns:toolkit="http://schemas.xceed.com/wpf/xaml/toolkit"
      d:DataContext="{d:DesignInstance Type=printing:PrintPreviewViewModel}"
      mc:Ignorable="d">
  <my:UserControlPrintPreview x:Name="preview"
                              Document="{Binding Document}"
                              LayoutSettingsCommand="{Binding LayoutSettingsCommand}"
                              PageSettingsCommand="{Binding PageSettingsCommand}"
                              PrintCommand="{Binding PrintCommand}" />
  <toolkit:BusyIndicator x:Name="bi" IsBusy="{Binding IsBusy, UpdateSourceTrigger=PropertyChanged}">
    <toolkit:BusyIndicator.ProgressBarStyle>
      <Style TargetType="ProgressBar">
        <Setter Property="Visibility" Value="Collapsed" />
      </Style>
    </toolkit:BusyIndicator.ProgressBarStyle>
    <toolkit:BusyIndicator.BusyContent>
      <StackPanel Orientation="Vertical">
        <TextBlock Margin="2" HorizontalAlignment="Center" Text="{Binding ProgressText}" />
      </StackPanel>
    </toolkit:BusyIndicator.BusyContent>
  </toolkit:BusyIndicator>
</Grid>
